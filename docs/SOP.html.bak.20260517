<!-- ============ 12. 常用命令 ============ -->
<section class="card" id="commands">
  <h2>⑫ 常用命令速查</h2>

  <h3>立即手动跑(测试用)</h3>
  <pre><code># 跑 daily_run(忽略非交易日)
.venv/bin/python scripts/daily_run.py --force --skip-universe

# 跑 morning_call(忽略非交易日)
.venv/bin/python scripts/morning_call.py --force

# 单步跑某一阶段
.venv/bin/python scripts/build_dragon_pool.py --config config.yaml --top 20 --allow-fallback
.venv/bin/python scripts/run_trader.py --config config.yaml --top 10
.venv/bin/python scripts/generate_daily_report.py --config config.yaml</code></pre>

  <h3>launchd 管理</h3>
  <pre><code># 查看注册状态
launchctl list | grep stockbot

# 立即触发(不等真实时间)
launchctl kickstart -k gui/$(id -u)/com.stockbot.daily-paper
launchctl kickstart -k gui/$(id -u)/com.stockbot.morning-call

# 卸载
launchctl bootout gui/$(id -u)/com.stockbot.daily-paper
launchctl bootout gui/$(id -u)/com.stockbot.morning-call

# 重新加载(改了 plist 后)
.venv/bin/python scripts/install_daily_launchd.py</code></pre>

  <h3>账户 / 订单管理</h3>
  <pre><code># 看待确认订单
.venv/bin/python scripts/confirm_manual_fill.py --list

# 确认成交
.venv/bin/python scripts/confirm_manual_fill.py --confirm 0 --price 10.89 --quantity 200

# 拒绝(从 pending 移除)
.venv/bin/python scripts/confirm_manual_fill.py --reject 0

# 查当前账户状态
cat stockbot/data/paper_account.json | python3 -m json.tool

# 查今日成交
tail -20 stockbot/logs/trades.csv</code></pre>

  <h3>实时日志</h3>
  <pre><code># launchd 输出
tail -f stockbot/logs/com.stockbot.daily-paper.out
tail -f stockbot/logs/com.stockbot.morning-call.out

# 最新一次 daily_run 的完整日志
ls -t stockbot/logs/daily/*.log | head -1 | xargs tail -50</code></pre>
</section>

